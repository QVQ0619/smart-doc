# ══════════════════════════════════════════════════════════════════════════
#  smart-doc-review 部署配置模板
#  用法：cp cicd/.env.example cicd/.env，按需修改后执行 cicd/deploy.sh
#  （cicd/.env 已被 .gitignore 忽略，密钥不会入库）
# ══════════════════════════════════════════════════════════════════════════

# ───────── 部署方式 ─────────
# build：本地构建镜像（VITE_BLADE_* 前端配置需编译进产物，改了下面的 VITE_ 值必须用 build）
# pull ：直接拉取 GHCR 流水线镜像（镜像内未烧录 Blade Token，前端会提示未配置）
DEPLOY_MODE=build
# pull 模式使用的镜像 tag（build 模式忽略）
SMART_DOC_IMAGE_TAG=latest

# ───────── 数据挂载（宿主机目录，相对 cicd/ 或写绝对路径）─────────
# MySQL 数据 → ${SMART_DOC_DATA_DIR}/mysql，上传文件/报告 → ${SMART_DOC_DATA_DIR}/storage
SMART_DOC_DATA_DIR=./data

# ───────── 端口 ─────────
HOST_APP_PORT=8000
HOST_MYSQL_PORT=3306

# ───────── 前端 Blade Agent 接入（构建期编译进前端产物）─────────
# Blade Agent API 基础地址（origin，不带路径）
VITE_BLADE_API_BASE=http://192.168.130.8:8020
# Blade API Key（形如 sk-blade-v2-...）。注意：会明文烧进镜像，仅限内网私有镜像使用
VITE_BLADE_TOKEN=
# 可选：指定解决方案 / 业务角色（留空用系统默认）
VITE_BLADE_SOLUTION_ID=
VITE_BLADE_BIZ_ROLE_ID=

# ───────── 数据库 ─────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DB=smart

# ───────── 后端 ─────────
# 写端点鉴权 key（为空则不鉴权，对外可达部署务必设置）
SMART_API_KEY=
# 登录 token 签名密钥，生产必须改掉默认值
SMART_AUTH_SECRET=smart-doc-dev-secret-change-me
# 允许跨域的前端 dev 来源（同源部署不需要改）
SMART_CORS_ORIGINS=http://localhost:3200
# 启动时幂等应用增量迁移
SMART_AUTO_MIGRATE=true
# 种入初始账号（admin/admin123 等）；生产环境建议 false
SMART_SEED_USERS=true
